{
  "name": "@kelo/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Design-system seam (plan-member-app §6): canonical CSS tokens + TS-consumable tokens.json, the Tailwind preset mapping them, the validated tenant brand layer, and the surface-neutral contract-bearing React components (§6.4) at ./react.",
  "exports": {
    "./tokens/tokens.css": "./tokens/tokens.css",
    "./tokens/tokens.json": "./tokens/tokens.json",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "default": "./dist/tailwind-preset.js"
    },
    "./brands/default.css": "./brands/default.css",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "tokens",
    "brands"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.react.json"
  },
  "dependencies": {
    "@kelo/contracts": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.19",
    "vitest": "4.1.10"
  }
}
