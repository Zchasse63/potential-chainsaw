{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "dist-test",
    "tsBuildInfoFile": "dist-test/tsconfig.test.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "include": ["test/**/*.ts", "test/**/*.tsx", "react/**/*.ts", "react/**/*.tsx"]
}
