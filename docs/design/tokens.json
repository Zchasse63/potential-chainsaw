{
  "$meta": {
    "system": "Kelo — Route 01 'The Quiet Instrument'",
    "date": "2026-07-17",
    "mode": "light-only-v1",
    "spacingBase": 4,
    "notes": "Values drop into the shadcn/ui + Tailwind token layer. Components are the fixed contract; iterate tokens, not component structure. All semantic fg/bg pairs listed together pass WCAG 2.2 AA."
  },
  "color": {
    "neutral": {
      "000": "#F5F6F6", "050": "#EFF1F1", "100": "#E7EAEA", "200": "#D8DCDD",
      "300": "#BEC4C6", "400": "#97A0A4", "500": "#6F7A80", "600": "#555F66",
      "700": "#40494F", "800": "#2A3238", "900": "#191F24", "ink": "#10161B"
    },
    "surface": {
      "app": "#F5F6F6", "card": "#FCFCFC", "input": "#FFFFFF",
      "inverse": "#10161B", "inverseBrand": "#1C2A37"
    },
    "brand": {
      "050": "#EDF1F4", "100": "#DCE4EA", "200": "#C1CFD9", "300": "#9BB0C0",
      "400": "#7290A5", "500": "#4F708A", "600": "#3E5A74", "700": "#324A60",
      "800": "#27394A", "900": "#1C2A37",
      "$usage": "600 = primary actions/selected. 050 = selected-row/active-nav bg. White text on 600/700 passes AA."
    },
    "birch": {
      "050": "#F5F0E6", "100": "#EBE1CE", "200": "#D9C9A9", "300": "#C1AB82",
      "400": "#9C875F", "500": "#746348", "text": "#5E4F38",
      "$usage": "MATERIAL, never status. Brand moments, imported-data surfaces, white-label warmth."
    },
    "success":  { "solid": "#2E7D56", "tint": "#E3F1E9", "onTint": "#265F44", "border": "#BFE0CE" },
    "warning":  { "solid": "#9A6B14", "tint": "#FAF1DC", "onTint": "#7A540F", "border": "#E0C98E" },
    "danger":   { "solid": "#B3453C", "tint": "#FAEAE8", "onTint": "#8F362E", "border": "#E5B3AD" },
    "info":     { "solid": "#3C6B96", "tint": "#E7F0F8", "onTint": "#305577", "border": "#9BB0C0" }
  },
  "domain": {
    "status-confirmed":      { "color": "success", "shape": "pill radius-full, tint bg", "icon": "check" },
    "status-processing":     { "color": "info", "shape": "radius 4-5, outlined on card bg", "icon": "clock" },
    "status-failed":         { "color": "danger", "shape": "radius 3, SOLID fill, white text", "icon": "x" },
    "status-refund-pending": { "color": "warning", "shape": "pill radius-full, DASHED 1px border, tint bg", "icon": "diamond" },
    "$rule": "Money states differ by shape + icon + color. Never color alone.",
    "freshness-live":           { "dot": "#2E7D56", "text": "#265F44", "chip": "card bg + hairline border, round dot" },
    "freshness-aged":           { "dot": "#97A0A4", "text": "#555F66", "chip": "card bg + hairline border", "label": "SYNCED {n}M" },
    "freshness-stale":          { "dot": "#9A6B14", "text": "#7A540F", "chip": "warning tint bg + warning border", "threshold": ">1h" },
    "freshness-stale-critical": { "dot": "#B3453C SQUARE (2px radius)", "text": "#8F362E", "chip": "danger tint bg + danger border, weight 600", "threshold": ">4h" },
    "data-native":   { "treatment": "solid hairline border, normal surfaces" },
    "data-imported": { "treatment": "repeating 45deg hatch #F5F0E6/#EBE1CE (8px stripes), dashed #9C875F border, text #5E4F38, source tag e.g. 'VIA GLOFOX', unverified figures carry trailing *" },
    "ai-accent": {
      "solid": "#2F7B80", "tint": "#E3F1F1", "surface": "#F7FBFB", "onTint": "#266064", "borderTint": "#A8D2D3",
      "draftSurface": "1.5px DOTTED #2F7B80 border, #F7FBFB bg; inner draft text box: card bg + 1px dashed #A8D2D3",
      "$rule": "Marks AI-generated content only. Used sparingly. Draft-shaped (dotted) until a human approves; approval is an explicit ceremony with a recipient-count verb ('Approve & send to 18')."
    }
  },
  "border": {
    "hairline": "1px solid rgba(16,22,27,.10)",
    "strong": "1px solid rgba(16,22,27,.16)",
    "dashed": "draft / money-in-transit / logo-slot placeholders",
    "dotted": "AI-drafted content (1.5px, ai-accent)"
  },
  "typography": {
    "families": {
      "display": "'Familjen Grotesk', sans-serif  (Google Fonts, SIL OFL)",
      "ui": "'Schibsted Grotesk', sans-serif  (Google Fonts, SIL OFL)",
      "mono": "'Spline Sans Mono', monospace  (Google Fonts, SIL OFL)"
    },
    "scale": {
      "display-xl": { "size": 48, "line": 52, "family": "display", "weight": 600, "tracking": "-0.025em" },
      "title":      { "size": 30, "line": 36, "family": "display", "weight": 600, "tracking": "-0.02em" },
      "title-sm":   { "size": 26, "line": 30, "family": "display", "weight": 600, "tracking": "-0.02em" },
      "heading":    { "size": 22, "line": 28, "family": "ui", "weight": 700 },
      "subheading": { "size": 17, "line": 24, "family": "ui", "weight": 600 },
      "body":       { "size": 14, "line": 20, "family": "ui", "weight": 400 },
      "body-sm":    { "size": 13, "line": 18, "family": "ui", "weight": 400 },
      "caption":    { "size": 12, "line": 16, "family": "ui", "weight": 500 },
      "data":       { "size": 13, "line": 20, "family": "mono", "weight": 500 },
      "data-lg":    { "size": 27, "line": 32, "family": "mono", "weight": 600, "tracking": "-0.02em", "$usage": "KPI values" },
      "micro":      { "size": 10.5, "line": 14, "family": "mono", "weight": 600, "tracking": "0.12em", "transform": "uppercase", "$usage": "section labels, provenance, chip text" }
    },
    "rules": [
      "Numbers meaning money/time/identity are always mono (tabular). Numbers in prose stay in UI face.",
      "Display face never below 20px; appears ~once per screen (greeting/page title).",
      "Two families max in app chrome; mono is the third voice reserved for data.",
      "Dense tables: 13px body, 10px mono headers with 0.10em tracking."
    ]
  },
  "radius": { "r1": 4, "r2": 6, "r3": 10, "r4": 16, "full": 999,
    "$usage": "r1 inputs/checkboxes · r2 buttons/rule-chips · r3 cards/banners · r4 modals/sheets · full pills/avatars/freshness chips" },
  "elevation": {
    "e0": "none + hairline border (default — most of the app is flat)",
    "e1": "0 1px 2px rgba(16,22,27,.06)  (raised: dropdowns)",
    "e2": "0 2px 8px rgba(16,22,27,.10)  (overlay: popovers, screen frames)",
    "e3": "0 8px 24px rgba(16,22,27,.14) (modal: approval ceremony, toasts)"
  },
  "motion": {
    "duration-1": "120ms  (hover, press)",
    "duration-2": "200ms  (state change, chips, confirmation tick)",
    "duration-3": "320ms  (panels, sheets)",
    "ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
    "ease-exit": "cubic-bezier(0.4, 0, 1, 1)",
    "reduced-motion": "opacity-only, 0ms movement",
    "$rule": "Motion confirms state changes and nothing else. No ambient animation, no parallax."
  },
  "sizing": {
    "target-min": 44,
    "target-desk": 48,
    "button-desk-primary": 56,
    "sidebar": 232,
    "$rule": "Front-desk tablet: every tap target >= 48px."
  }
}
