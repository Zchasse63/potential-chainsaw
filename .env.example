# Copy to .env and fill. Real values: local .env (never committed) / Netlify env / Supabase Vault.
GLOFOX_API_KEY=
GLOFOX_API_TOKEN=
GLOFOX_BRANCH_ID=
GLOFOX_NAMESPACE=
GLOFOX_BASE_URL=https://gf-api.aws.glofox.com/prod
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# a.k.a. the anon key — the name @kelo/db's createAnonClient() reads.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Communications (Phase 3.1). Empty provider credentials intentionally select
# dry-run mode; no adapter performs a network call until credentials exist.
RESEND_API_KEY=
RESEND_FROM=
RESEND_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
# Optional webhook-only binding of Twilio's same primary Auth Token.
TWILIO_WEBHOOK_AUTH=

# Stripe billing spine (Phase 5). No Connect account exists yet (BLOCKERS P0-5);
# an empty STRIPE_SECRET_KEY intentionally selects dry-run mode — the adapter
# returns synthetic ids and performs NO network call. The platform secret and
# the per-endpoint webhook signing secret live only in Netlify function env
# (threat-model §6); never client-side, never in the repo.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Workers / jobs queue (Phase 0.3). SUPABASE_DB_URL is the direct Postgres
# connection string workers use (service-level) to call app.* queue functions,
# which live in the non-PostgREST-exposed `app` schema. Never the anon key.
SUPABASE_DB_URL=
# External dead-man heartbeat the scheduler tick pings each cycle (Healthchecks.io / BetterStack).
HEARTBEAT_PING_URL=
# Internal shared secret the worker background function verifies (threat model §6).
WORKER_SHARED_SECRET=
# Optional: path to (or PEM of) the Supabase Root CA for full TLS verification
# on pooler connections (download from the Supabase dashboard / their docs).
SUPABASE_DB_SSL_CA=
